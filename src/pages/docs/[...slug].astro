---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import Layout from '../../layouts/Layout.astro';
import { DocumentRenderer } from '@keystatic/core/renderer';

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), keystaticConfig);
  const docs = await reader.collections.docs.all();
  return docs.map(doc => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { content, title } = doc.entry;
const { node } = await content();

// Helper to extract plain text from Markdoc nodes
function extractText(n: any): string {
  if (typeof n === 'string') return n;
  if (n.attributes?.content !== undefined) return n.attributes.content;
  if (n.children) return n.children.map(extractText).join('');
  return '';
}

// Extract headings for TOC
const headings = (node.children || [])
  .filter(child => child.type === 'heading')
  .map(heading => {
    const text = extractText(heading);
    return {
      depth: heading.attributes.level || 1,
      text,
      slug: text.toLowerCase().replace(/[^\w]+/g, '-')
    };
  });
---

<Layout title={`${title} | Design System Docs`} headings={headings}>
  <article class="prose">
    <h1 id="top">{title}</h1>
    
    {node.children.map((child: any) => {
      // Simple recursive renderer for Markdoc tags
      function renderNode(n: any): any {
        if (typeof n === 'string') return n;
        if (n.type === 'text') return n.attributes.content;
        
        const children = n.children?.map(renderNode) || [];
        
        switch (n.type) {
          case 'heading':
            const HeadTag = `h${n.attributes.level}`;
            const slug = extractText(n).toLowerCase().replace(/[^\w]+/g, '-');
            return <HeadTag id={slug}>{children}</HeadTag>;
          case 'paragraph':
            return <p>{children}</p>;
          case 'list':
            const ListTag = n.attributes.ordered ? 'ol' : 'ul';
            return <ListTag>{children}</ListTag>;
          case 'item':
            return <li>{children}</li>;
          case 'blockquote':
            return <blockquote>{children}</blockquote>;
          case 'code':
            return n.attributes.inline ? <code>{n.attributes.content}</code> : <pre><code>{n.attributes.content}</code></pre>;
          case 'link':
            return <a href={n.attributes.href}>{children}</a>;
          case 'strong':
            return <strong>{children}</strong>;
          case 'em':
            return <em>{children}</em>;
          case 'hr':
            return <hr />;
          default:
            return <div>{children}</div>;
        }
      }
      return renderNode(child);
    })}
  </article>
</Layout>

<style is:global>
  .prose {
    max-width: 100%;
    color: var(--color-text);
    line-height: 1.6;
  }
  .prose h1 { font-size: var(--font-size-3xl); margin-bottom: var(--space-8); font-weight: var(--font-weight-bold); }
  .prose h2 { font-size: var(--font-size-2xl); margin-top: var(--space-12); margin-bottom: var(--space-6); font-weight: var(--font-weight-semibold); border-bottom: 1px solid var(--color-border); padding-bottom: var(--space-2); }
  .prose h3 { font-size: var(--font-size-xl); margin-top: var(--space-8); margin-bottom: var(--space-4); font-weight: var(--font-weight-semibold); }
  .prose p { margin-bottom: var(--space-6); }
  .prose ul, .prose ol { margin-bottom: var(--space-6); padding-left: var(--space-6); }
  .prose li { margin-bottom: var(--space-2); }
  .prose blockquote { border-left: 4px solid var(--color-border); padding-left: var(--space-6); color: var(--color-text-subtle); font-style: italic; margin-bottom: var(--space-6); }
  .prose pre { background: var(--color-code-bg); padding: var(--space-4); border-radius: var(--radius-md); overflow-x: auto; margin-bottom: var(--space-6); }
  .prose code { font-family: var(--font-mono); font-size: 0.9em; background: var(--color-code-bg); padding: 0.2em 0.4em; border-radius: var(--radius-sm); }
  .prose pre code { background: none; padding: 0; }
  .prose a { color: var(--color-primary); text-decoration: underline; text-underline-offset: 4px; }
</style>
