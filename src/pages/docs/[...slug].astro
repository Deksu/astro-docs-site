---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import { getAllDocs } from '../../utils/docs';

export async function getStaticPaths() {
  const docs = await getAllDocs();
  return docs.map(doc => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { body, title } = doc;

const slugify = (text: string) =>
  text
    .toLowerCase()
    .replace(/[^\w]+/g, '-')
    .replace(/(^-|-$)+/g, '');

const tokens = marked.lexer(body || '');
const headings = tokens
  .filter((token) => token.type === 'heading' && token.depth >= 2)
  .map((token) => ({
    depth: token.depth,
    text: token.text,
    slug: slugify(token.text)
  }));

const html = marked.parse(body || '');
---

<Layout title={`${title} | Design System Docs`} headings={headings}>
  <article class="prose" set:html={html} />
</Layout>

<style is:global>
  .prose {
    max-width: 100%;
    color: var(--color-text);
    line-height: 1.6;
  }
  .prose h1 { font-size: var(--font-size-3xl); margin-bottom: var(--space-8); font-weight: var(--font-weight-bold); }
  .prose h2 { font-size: var(--font-size-2xl); margin-top: var(--space-12); margin-bottom: var(--space-6); font-weight: var(--font-weight-semibold); border-bottom: 1px solid var(--color-border); padding-bottom: var(--space-2); }
  .prose h3 { font-size: var(--font-size-xl); margin-top: var(--space-8); margin-bottom: var(--space-4); font-weight: var(--font-weight-semibold); }
  .prose p { margin-bottom: var(--space-6); }
  .prose ul, .prose ol { margin-bottom: var(--space-6); padding-left: var(--space-6); }
  .prose li { margin-bottom: var(--space-2); }
  .prose blockquote { border-left: 4px solid var(--color-border); padding-left: var(--space-6); color: var(--color-text-subtle); font-style: italic; margin-bottom: var(--space-6); }
  .prose pre { background: var(--color-code-bg); padding: var(--space-4); border-radius: var(--radius-md); overflow-x: auto; margin-bottom: var(--space-6); }
  .prose code { font-family: var(--font-mono); font-size: 0.9em; background: var(--color-code-bg); padding: 0.2em 0.4em; border-radius: var(--radius-sm); }
  .prose pre code { background: none; padding: 0; }
  .prose a { color: var(--color-primary); text-decoration: underline; text-underline-offset: 4px; }
</style>
