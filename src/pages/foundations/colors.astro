---
import Layout from '../../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import styles from '../../styles/Colors.module.css';
import fallbackTokens from '../../data/tokens.json';

const reader = createReader(process.cwd(), keystaticConfig);
let tokensData = null;
try {
  tokensData = await reader.singletons.tokens.read();
} catch (error) {
  tokensData = null;
}

const tokens = tokensData || fallbackTokens;
const backgroundTokens = tokens?.color?.background ?? [];
const borderTokens = tokens?.color?.border ?? [];
const foregroundTokens = tokens?.color?.foreground ?? [];

const colorSections = [
  {
    title: 'Backgrounds',
    description: 'Foundational surfaces used across layouts and cards.',
    items: backgroundTokens.map((token) => ({
      name: token.name,
      token: token.token,
      value: token.value,
      desc: token.usage
    }))
  },
  {
    title: 'Borders',
    description: 'Dividers and outlines that separate structure and hierarchy.',
    items: borderTokens.map((token) => ({
      name: token.name,
      token: token.token,
      value: token.value,
      desc: token.usage
    }))
  },
  {
     title: 'Foreground',
     description: 'Text, links, and interactive emphasis colors.',
     items: foregroundTokens.map((token) => ({
       name: token.name,
       token: token.token,
       value: token.value,
       desc: token.usage
     }))
  }
];
---

<Layout title="Colors | Foundations">
  <div class={styles.header}>
    <h1>Colors</h1>
    <p class={styles.subtitle}>Our brand color palette is designed for high contrast and modern aesthetics.</p>
  </div>

  {colorSections.map(section => (
    <div class={styles.section}>
      <h2>{section.title}</h2>
      <p class={styles.groupDescription}>{section.description}</p>
      
      <div class={styles.grid}>
        {section.items.map(item => (
          <div class={styles.swatch}>
            <div class={styles.preview} style={`background-color: ${item.value}`}></div>
            <div class={styles.info}>
              <h3 class={styles.name}>{item.name}</h3>
              <div class={styles.token}><code>{item.token}</code></div>
              <div class={styles.values}>
                <div class={styles.label}>Value</div>
                <div class={styles.valueText}>{item.value.toUpperCase()}</div>
                <div class={styles.label}>Usage</div>
                <div class={styles.valueText}>{item.desc}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
</Layout>

<style>
  .group {
    margin-bottom: var(--space-16);
  }
  .groupTitle {
    font-size: var(--font-size-2xl);
    margin-top: 0;
  }
  .groupDesc {
    color: var(--color-text-subtle);
    margin-bottom: var(--space-8);
  }
</style>
