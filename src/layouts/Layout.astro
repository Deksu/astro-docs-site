---
interface Props {
	title?: string;
	headings?: { depth: number; text: string; slug: string }[];
}

const { title = "Design System Docs", headings = [] } = Astro.props;
import '../styles/global.css';
import styles from '../styles/Shell.module.css';

import { buildSearchIndex, normalizeSearchItems } from '../utils/searchIndex';
import { getAllDocs } from '../utils/docs';

const docs = await getAllDocs();

// Group docs by section
const sections = {
	'getting-started': { label: 'Getting Started', items: [] as any[] },
	'foundations': { 
		label: 'Foundations', 
		items: [
			{ slug: 'colors', entry: { title: 'Colors', order: 0 }, manual: true, href: '/foundations/colors' },
			{ slug: 'typography', entry: { title: 'Typography', order: 1 }, manual: true, href: '/foundations/typography' },
		] as any[] 
	},
	'components': { label: 'Components', items: [] as any[] },
	'tokens': {
		label: 'Tokens',
		items: [
			{ slug: 'tokens-overview', entry: { title: 'Overview', order: 0 }, manual: true, href: '/tokens/overview' },
			{ slug: 'tokens-color', entry: { title: 'Color', order: 1 }, manual: true, href: '/tokens/color' },
			{ slug: 'tokens-typography', entry: { title: 'Typography', order: 2 }, manual: true, href: '/tokens/typography' },
		] as any[]
	}
};

docs.forEach(doc => {
	const section = doc.section as keyof typeof sections;
	if (sections[section]) {
		// Avoid duplicates if we manually added it
		if (!sections[section].items.some(i => i.slug === doc.slug)) {
			sections[section].items.push(doc);
		}
	}
});

// Sort items within sections by order
Object.values(sections).forEach(section => {
	section.items.sort((a, b) => (a.order || 0) - (b.order || 0));
});

const currentPath = Astro.url.pathname;

const searchItems = normalizeSearchItems(
	[
		...buildSearchIndex(docs, sections),
		{ title: 'Colors', href: '/foundations/colors', section: 'foundations', sectionLabel: 'Foundations' },
		{ title: 'Typography', href: '/foundations/typography', section: 'foundations', sectionLabel: 'Foundations' },
		{ title: 'Tokens Overview', href: '/tokens/overview', section: 'tokens', sectionLabel: 'Tokens' },
		{ title: 'Color Tokens', href: '/tokens/color', section: 'tokens', sectionLabel: 'Tokens' },
		{ title: 'Typography Tokens', href: '/tokens/typography', section: 'tokens', sectionLabel: 'Tokens' }
	],
	sections
);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class={styles.shell}>
			<header class={styles.header}>
				<a href="/" class={styles.logo}>
					<span>DS Docs</span>
				</a>
				<div class={styles.searchWrapper} data-search-wrapper>
					<input
						type="text"
						class={styles.searchInput}
						placeholder="Search"
						aria-label="Search documentation"
					/>
					<button
						class={styles.searchClear}
						type="button"
						aria-label="Clear search"
						data-search-clear
						data-visible-class={styles.searchClearVisible}
					>
						<svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
							<path
								fill="currentColor"
								d="M4.22 4.22a.75.75 0 0 1 1.06 0L8 6.94l2.72-2.72a.75.75 0 1 1 1.06 1.06L9.06 8l2.72 2.72a.75.75 0 1 1-1.06 1.06L8 9.06l-2.72 2.72a.75.75 0 1 1-1.06-1.06L6.94 8 4.22 5.28a.75.75 0 0 1 0-1.06Z"
							/>
						</svg>
					</button>
					<span
						class={styles.searchShortcut}
						data-search-shortcut
						data-hidden-class={styles.searchShortcutHidden}
					>⌘K</span>
					<div
						class={styles.searchMenu}
						role="listbox"
						aria-label="Search results"
						data-search-menu
						data-open-class={styles.searchMenuOpen}
						data-item-class={styles.searchItem}
						data-item-title-class={styles.searchItemTitle}
						data-item-meta-class={styles.searchItemMeta}
						data-empty-class={styles.searchEmpty}
					></div>
				</div>
                <div style="flex: 1;"></div>
			</header>

			<div class={styles.mainWrapper}>
				<aside class={styles.sidebar}>
					<nav>
						{Object.entries(sections).map(([id, section]) => (
							section.items.length > 0 && (
								<>
									<div class={styles.navSectionTitle}>{section.label}</div>
									{section.items.map(item => {
										const href = item.href || `/docs/${item.slug}`;
										const isActive = currentPath === href || (currentPath === '/' && item.slug === 'welcome');
										return (
											<a 
												href={href} 
												class={`${styles.navItem} ${isActive ? styles.navItemActive : ''}`}
											>
												{item.title}
											</a>
										);
									})}
								</>
							)
						))}
					</nav>
				</aside>

				<main class={styles.content}>
					<slot />
				</main>

				<aside class={styles.toc}>
					{headings.length > 0 && (
						<>
							<div class={styles.navSectionTitle}>On this page</div>
							<nav>
								{headings.map(heading => (
									<a 
										href={`#${heading.slug}`} 
										class={styles.navItem}
										data-toc-link
										data-active-class={styles.tocItemActive}
										style={`margin-left: ${(heading.depth - 1) * 1}rem;`}
									>
										{heading.text}
									</a>
								))}
							</nav>
						</>
					)}
				</aside>
			</div>
		</div>
		<script define:vars={{ searchIndex: searchItems }}>
			const searchData = Array.isArray(searchIndex) ? searchIndex : [];
			const copyButtons = document.querySelectorAll('[data-copy]');
			copyButtons.forEach((button) => {
				button.addEventListener('click', async () => {
					const value = button.getAttribute('data-copy');
					if (!value) return;
					try {
						await navigator.clipboard.writeText(value);
						button.setAttribute('data-state', 'copied');
						const tooltip = button.querySelector('[data-copy-tooltip]');
						if (tooltip) tooltip.textContent = 'Copied';
						window.setTimeout(() => {
							button.removeAttribute('data-state');
							if (tooltip) tooltip.textContent = 'Copy to clipboard';
						}, 1200);
					} catch (err) {
						console.warn('Copy failed', err);
					}
				});
			});

			const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
			const sections = tocLinks
				.map((link) => document.querySelector(link.getAttribute('href')))
				.filter(Boolean);
			if (sections.length > 0) {
				const observer = new IntersectionObserver(
					(entries) => {
						const visible = entries
							.filter((entry) => entry.isIntersecting)
							.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
						if (!visible) return;
						const id = `#${visible.target.id}`;
						tocLinks.forEach((link) => {
							const isActive = link.getAttribute('href') === id;
							const activeClass = link.getAttribute('data-active-class');
							if (activeClass) {
								link.classList.toggle(activeClass, isActive);
							}
						});
					},
					{ rootMargin: '-20% 0px -65% 0px', threshold: [0, 0.4, 1] }
				);
				sections.forEach((section) => observer.observe(section));
			}

			const searchInput = document.querySelector('input[aria-label="Search documentation"]');
			const searchMenu = document.querySelector('[data-search-menu]');
			const searchClear = document.querySelector('[data-search-clear]');
			const searchWrapper = document.querySelector('[data-search-wrapper]');
			const searchShortcut = document.querySelector('[data-search-shortcut]');
			function renderResults(results) {
				searchMenu.innerHTML = '';
				if (results.length === 0) {
					const empty = document.createElement('div');
					empty.className = searchMenu.getAttribute('data-empty-class') || '';
					empty.textContent = 'No results';
					searchMenu.appendChild(empty);
					return;
				}
				results.forEach((item) => {
					const link = document.createElement('a');
					link.href = item.href;
					link.className = searchMenu.getAttribute('data-item-class') || '';
					const title = document.createElement('div');
					title.textContent = item.title;
					title.className = searchMenu.getAttribute('data-item-title-class') || '';
					const meta = document.createElement('div');
					meta.textContent = item.sectionLabel || item.section.replace('-', ' ');
					meta.className = searchMenu.getAttribute('data-item-meta-class') || '';
					link.appendChild(title);
					link.appendChild(meta);
					searchMenu.appendChild(link);
				});
			}

			function updateSearch() {
				if (!searchMenu || !searchClear) return;
				const query = searchInput.value.trim().toLowerCase();
				const clearVisibleClass = searchClear.getAttribute('data-visible-class');
				const menuOpenClass = searchMenu.getAttribute('data-open-class');
				const shortcutHiddenClass = searchShortcut?.getAttribute('data-hidden-class');
				if (clearVisibleClass) {
					searchClear.classList.toggle(clearVisibleClass, query.length > 0);
				}
				if (menuOpenClass) {
					searchMenu.classList.toggle(menuOpenClass, query.length > 0);
				}
				if (shortcutHiddenClass && searchShortcut) {
					searchShortcut.classList.toggle(shortcutHiddenClass, query.length > 0);
				}
				if (!query) {
					searchMenu.innerHTML = '';
					return;
				}
				const results = searchData
					.filter((item) => item.title.toLowerCase().includes(query))
					.slice(0, 8);
				renderResults(results);
			}

			if (searchInput && searchMenu && searchClear) {
				searchInput.addEventListener('input', updateSearch);
				searchInput.addEventListener('focus', updateSearch);
			}

			if (searchClear && searchInput) {
				searchClear.addEventListener('click', () => {
					searchInput.value = '';
					updateSearch();
					searchInput.focus();
				});
			}

			if (searchMenu) {
				document.addEventListener('click', (event) => {
					const target = event.target;
					if (!target.closest('[data-search-wrapper]')) {
						const menuOpenClass = searchMenu.getAttribute('data-open-class');
						if (menuOpenClass) {
							searchMenu.classList.remove(menuOpenClass);
						}
					}
				});
			}

			document.addEventListener('keydown', (event) => {
				if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
					event.preventDefault();
					searchInput?.focus();
					searchInput?.select();
				}
			});
		</script>
	</body>
</html>
